{
  "manifest_version": 3,
  "name": "KeepStacking",
  "version": "1.0.0",
  "description": "Track your total spending on prop trading platforms, with smart monthly caching.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "https://bulenox.com/*",
    "https://dashboard.apextraderfunding.com/*",
    "https://dash.lucidtrading.com/*",
    "https://myfundedfutures.com/*",
    "https://api.myfundedfutures.com/*",
    "https://app.alpha-futures.com/*",
    "https://backend.alpha-futures.com/*",
    "https://takeprofittrader.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
